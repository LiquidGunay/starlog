{
  "name": "mobile",
  "private": true,
  "version": "0.1.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "start:dev-client": "APP_VARIANT=development expo start --dev-client",
    "android": "expo start --android",
    "android:dev": "APP_VARIANT=development expo start --dev-client --android",
    "android:local": "APP_VARIANT=development expo run:android --device",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:android:development": "eas build --platform android --profile development",
    "build:android:preview": "eas build --platform android --profile preview",
    "build:android:production": "eas build --platform android --profile production"
  },
  "dependencies": {
    "expo": "~51.0.0",
    "expo-av": "~14.0.7",
    "expo-dev-client": "~4.0.29",
    "expo-file-system": "~17.0.1",
    "expo-notifications": "~0.28.19",
    "expo-speech": "~12.0.2",
    "expo-sqlite": "~14.0.6",
    "expo-status-bar": "~1.12.1",
    "react": "18.2.0",
    "react-native": "0.74.5"
  },
  "devDependencies": {
    "@types/react": "18.3.9",
    "typescript": "5.6.3"
  }
}
