{
  "name": "mobile",
  "private": true,
  "version": "0.1.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "start:dev-client": "APP_VARIANT=development expo start --dev-client",
    "start:dev-client:lan": "APP_VARIANT=development REACT_NATIVE_PACKAGER_HOSTNAME=${REACT_NATIVE_PACKAGER_HOSTNAME:-192.168.0.102} expo start --dev-client --host lan --port 8081",
    "android": "expo run:android",
    "android:dev": "APP_VARIANT=development expo start --dev-client --android",
    "android:local": "APP_VARIANT=development expo run:android --device",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "postinstall": "patch-package",
    "build:android:development": "eas build --platform android --profile development",
    "build:android:preview": "eas build --platform android --profile preview",
    "build:android:production": "eas build --platform android --profile production",
    "verify:android:production-config": "APP_VARIANT=production ./node_modules/.bin/expo config --json",
    "build:android:production:local": "../../scripts/android_prepare_production_release.sh",
    "test:briefing-date": "./node_modules/.bin/tsc -p tsconfig.briefing-date-tests.json --outDir /tmp/mobile-briefing-date-tests && node /tmp/mobile-briefing-date-tests/apps/mobile/tests/mobile-briefing-date.test.js",
    "test:planner-functional": "./node_modules/.bin/tsc -p tsconfig.planner-tests.json && node ../../.tmp/mobile-planner-tests/apps/mobile/tests/mobile-planner-view-model.test.js",
    "test:review-functional": "./node_modules/.bin/tsc -p tsconfig.review-tests.json && node ../../.tmp/mobile-review-tests/apps/mobile/tests/mobile-review-view-model.test.js",
    "test:study-mutations": "./node_modules/.bin/tsc -p tsconfig.study-mutations-tests.json --outDir /tmp/mobile-study-mutations-tests && node /tmp/mobile-study-mutations-tests/apps/mobile/tests/mobile-study-mutations.test.js",
    "test:assistant-thread-actions": "./node_modules/.bin/tsc -p tsconfig.assistant-thread-actions-tests.json --outDir /tmp/mobile-assistant-thread-actions-tests && node /tmp/mobile-assistant-thread-actions-tests/apps/mobile/tests/assistant-mobile-thread-actions.test.js",
    "test:assistant-aui": "./node_modules/.bin/tsc -p tsconfig.assistant-aui-tests.json && node ../../.tmp/mobile-assistant-aui-tests/apps/mobile/tests/mobile-assistant-aui-adapter.test.js",
    "test:assistant-ui-render": "if [ -f ./node_modules/typescript/bin/tsc ]; then ./node_modules/.bin/tsc -p tsconfig.assistant-ui-render-tests.json; else node ../../node_modules/.pnpm/typescript@5.3.3/node_modules/typescript/bin/tsc -p tsconfig.assistant-ui-render-tests.json; fi && node /tmp/mobile-assistant-ui-render-tests/apps/mobile/tests/mobile-assistant-ui-render-harness.test.js"
  },
  "dependencies": {
    "@assistant-ui/core": "0.2.2",
    "@assistant-ui/react-native": "0.1.16",
    "@babel/runtime": "^7.28.6",
    "@expo/vector-icons": "^14.0.2",
    "@react-native/assets-registry": "0.74.87",
    "@react-native/gradle-plugin": "0.74.87",
    "@starlog/contracts": "workspace:*",
    "assistant-cloud": "0.1.27",
    "expo": "~51.0.0",
    "expo-asset": "~10.0.10",
    "expo-av": "~14.0.7",
    "expo-dev-client": "~4.0.29",
    "expo-file-system": "~17.0.1",
    "expo-linking": "~6.3.1",
    "expo-notifications": "~0.28.19",
    "expo-secure-store": "~13.0.2",
    "expo-share-intent": "^2.0.0",
    "expo-speech": "~12.0.2",
    "expo-sqlite": "~14.0.6",
    "expo-status-bar": "~1.12.1",
    "expo-system-ui": "~3.0.7",
    "patch-package": "^8.0.1",
    "react": "18.2.0",
    "react-native": "0.74.5",
    "web-streams-polyfill": "3.3.3"
  },
  "devDependencies": {
    "@types/react": "~18.2.79",
    "typescript": "~5.3.3"
  }
}
