FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

WORKDIR /app

# Railway deploys this service from the repo root, so copy from the nested path.
# This keeps the API build isolated while still using the repo-wide lockfile scan.
COPY services/api/pyproject.toml /app/pyproject.toml
COPY services/api/app /app/app

RUN pip install --no-cache-dir --upgrade pip && pip install --no-cache-dir -e .

CMD ["sh", "-c", "uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8000}"]
