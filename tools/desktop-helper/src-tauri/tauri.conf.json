{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Starlog Desktop Helper",
  "version": "0.1.0",
  "identifier": "com.starlog.desktophelper",
  "build": {
    "beforeDevCommand": "node ./scripts/sync_product_copy.mjs",
    "beforeBuildCommand": "node ./scripts/sync_product_copy.mjs",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Starlog Helper",
        "width": 390,
        "height": 430,
        "resizable": false,
        "maximizable": false,
        "minWidth": 390,
        "minHeight": 430
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": false,
    "category": "Productivity",
    "shortDescription": "Capture desktop clips and screenshots into Starlog.",
    "longDescription": "Starlog Desktop Helper captures clipboard and screenshot content from desktop apps, enriches with active-window metadata, and uploads to Starlog with local OCR when available.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
